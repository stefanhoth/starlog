{
  "name": "starlog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test:e2e": "docker run --rm --ipc=host -v \"$(pwd):/work\" -w /work mcr.microsoft.com/playwright:v1.60.0-noble sh -c 'npm ci && npx playwright test'",
    "test:e2e:cloud": "PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers npx playwright install chromium && PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers npx playwright test",
    "test:unit": "vitest run",
    "test:prompts": "npx tsx tests/prompts/eval.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "daisyui": "^4.12.24",
    "idb": "^8.0.3"
  }
}
